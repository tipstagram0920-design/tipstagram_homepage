generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  password      String?
  image         String?
  role          Role      @default(USER)
  tags          String[]  @default([])
  contactId     String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts   Account[]
  sessions   Session[]
  purchases  Purchase[]
  progresses Progress[]
  posts      Post[]
  contact    Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  homeworkSubmissions HomeworkSubmission[]
  challengeEnrollments ChallengeEnrollment[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Product {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  subtitle    String?
  description       String  @db.Text
  descriptionDesign String? @db.Text
  price             Int
  thumbnail   String?
  highlights  String[] @default([])
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course         Course?
  purchases      Purchase[]
  coupons        Coupon[]
  emailTemplates EmailTemplate[]

  @@map("products")
}

model Course {
  id        String   @id @default(cuid())
  productId String   @unique
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  sections Section[]

  @@map("courses")
}

model Section {
  id       String @id @default(cuid())
  courseId String
  title    String
  order    Int    @default(0)

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@map("sections")
}

model Lesson {
  id        String  @id @default(cuid())
  sectionId String
  title     String
  vimeoId   String?
  duration  Int?
  order     Int     @default(0)
  isFree    Boolean @default(false)

  section    Section    @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progresses Progress[]

  @@map("lessons")
}

model Purchase {
  id           String    @id @default(cuid())
  userId       String
  productId    String
  amount       Int
  couponId     String?
  orderId      String    @unique
  createdAt    DateTime  @default(now())
  refundedAt   DateTime?
  refundReason String?
  refundedBy   String?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  coupon  Coupon? @relation(fields: [couponId], references: [id])

  @@index([refundedAt])
  @@map("purchases")
}

model Progress {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("progresses")
}

model Coupon {
  id        String    @id @default(cuid())
  code      String    @unique
  discount  Int
  type      String    @default("PERCENT")
  maxUses   Int?
  uses      Int       @default(0)
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  productId String?
  createdAt DateTime  @default(now())

  product   Product?   @relation(fields: [productId], references: [id])
  purchases Purchase[]

  @@map("coupons")
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  thumbnail String?
  authorId  String
  views     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("posts")
}

model Slide {
  id         String   @id @default(cuid())
  title      String
  subtitle   String?
  image      String?
  link       String?
  buttonText String?
  bgColor    String?
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@map("slides")
}

model Page {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String   @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("pages")
}

model HomepageBlock {
  id        String   @id @default(cuid())
  section   String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  data      String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("homepage_blocks")
}

model EmailTemplate {
  id        String   @id @default(cuid())
  type      String
  productId String?
  name      String
  subject   String
  html      String   @db.Text
  design    String?  @db.Text
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([type, productId])
  @@map("email_templates")
}

model LiveSignup {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  sentAt    DateTime?
  contactId String?
  createdAt DateTime  @default(now())

  contact   Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([contactId])
  @@map("live_signups")
}

model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ============================================================================
// CRM (Phase 1)
// ============================================================================

model Contact {
  id              String     @id @default(cuid())
  email           String     @unique
  phone           String?
  name            String?
  tags            String[]   @default([])
  source          String?
  firstSeenAt     DateTime   @default(now())
  lastSeenAt     DateTime   @updatedAt
  consentEmail    Boolean    @default(true)
  consentSms      Boolean    @default(false)
  unsubscribedAt  DateTime?
  note            String?    @db.Text

  // 카운터 캐시 (집계 빠른 조회)
  liveSignupCount Int        @default(0)
  purchaseCount   Int        @default(0)
  totalSpent      Int        @default(0)

  user                 User?
  liveSignups          LiveSignup[]
  events               Event[]
  workflowRuns         WorkflowRun[]
  ebookSubmissions     EbookSubmission[]
  consultationRequests ConsultationRequest[]
  freebieSubmissions   FreebieSubmission[]
  webinarQuestions     WebinarQuestion[]

  @@index([lastSeenAt])
  @@index([source])
  @@map("contacts")
}

model Event {
  id         String   @id @default(cuid())
  contactId  String
  type       String
  payload    Json?
  occurredAt DateTime @default(now())

  contact    Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId, occurredAt])
  @@index([type, occurredAt])
  @@map("events")
}

model MessageLog {
  id                 String   @id @default(cuid())
  contactId          String?
  channel            String
  provider           String
  to                 String
  templateKey        String?
  templateExternalId String?
  subject            String?
  body               String   @db.Text
  status             String
  error              String?  @db.Text
  externalId         String?
  sentAt             DateTime @default(now())

  @@index([contactId, sentAt])
  @@index([status])
  @@map("message_logs")
}

model Workflow {
  id         String   @id @default(cuid())
  name       String
  trigger    String
  conditions Json?
  steps      Json
  isActive   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  runs       WorkflowRun[]

  @@map("workflows")
}

model WorkflowRun {
  id          String    @id @default(cuid())
  workflowId  String
  contactId   String
  currentStep Int       @default(0)
  nextRunAt   DateTime?
  status      String    @default("pending")
  context     Json?
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  workflow    Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([status, nextRunAt])
  @@map("workflow_runs")
}

model BroadcastDraft {
  id          String    @id @default(cuid())
  channel     String
  title       String
  body        String    @db.Text
  scheduledAt DateTime
  status      String    @default("scheduled")
  notifiedAt  DateTime?
  doneAt      DateTime?
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())

  @@index([scheduledAt, status])
  @@map("broadcast_drafts")
}

model EbookSubmission {
  id            String    @id @default(cuid())
  level         Int       // 1 = 신청, 2 = 인증 제출
  name          String?
  email         String
  screenshotUrl String?
  contactId     String?
  sentAt        DateTime?
  createdAt     DateTime  @default(now())

  contact       Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([level, createdAt])
  @@index([contactId])
  @@map("ebook_submissions")
}

model ConsultationRequest {
  id               String   @id @default(cuid())
  name             String
  email            String
  phone            String?
  instagramHandle  String?
  followerCount    String?  // 자유 텍스트 (정확한 숫자 안 받음)
  painPoint        String   @db.Text
  contactId        String?
  status           String   @default("pending") // pending | selected | done | rejected
  sentAt           DateTime?
  createdAt        DateTime @default(now())

  contact          Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([status])
  @@index([contactId])
  @@map("consultation_requests")
}

model WebinarCampaign {
  id             String    @id @default(cuid())
  name           String
  webinarDate    DateTime
  endDate        DateTime?
  zoomUrl        String?
  salesUrl       String?
  preQuestionUrl String?
  kakaoChatUrl   String?
  replayUrl      String?
  audience       Json
  steps          Json
  isActive       Boolean   @default(false)
  skipPast       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  sends          WebinarCampaignSend[]
  questions      WebinarQuestion[]

  @@map("webinar_campaigns")
}

model WebinarQuestion {
  id         String   @id @default(cuid())
  campaignId String
  name       String?
  email      String
  question   String   @db.Text
  contactId  String?
  createdAt  DateTime @default(now())

  campaign   WebinarCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact    Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([campaignId, createdAt])
  @@index([email])
  @@index([contactId])
  @@map("webinar_questions")
}

model WebinarCampaignSend {
  id         String   @id @default(cuid())
  campaignId String
  stepIndex  Int
  contactId  String
  status     String
  error      String?
  sentAt     DateTime @default(now())

  campaign   WebinarCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, stepIndex, contactId])
  @@index([campaignId, sentAt])
  @@map("webinar_campaign_sends")
}

model OperatorTask {
  id          String    @id @default(cuid())
  title       String
  detail      String?   @db.Text
  scheduledAt DateTime
  campaignId  String?   // 캠페인 자동 시드 시
  status      String    @default("pending") // pending | notified | done | skipped
  notifiedAt  DateTime?
  doneAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([scheduledAt, status])
  @@index([campaignId])
  @@map("operator_tasks")
}

model Freebie {
  id              String    @id @default(cuid())
  slug            String    @unique
  title           String
  subtitle        String?
  description     String?   @db.Text
  fileUrl         String?
  thumbnail       String?
  category        String?
  customEmailBody String?   @db.Text
  showLivePromo   Boolean   @default(true)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  submissions     FreebieSubmission[]

  @@map("freebies")
}

model FreebieSubmission {
  id         String   @id @default(cuid())
  freebieId  String
  name       String?
  email      String
  contactId  String?
  sentAt     DateTime?
  createdAt  DateTime @default(now())

  freebie    Freebie  @relation(fields: [freebieId], references: [id], onDelete: Cascade)
  contact    Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([freebieId, createdAt])
  @@index([email])
  @@index([contactId])
  @@map("freebie_submissions")
}

model TrackEvent {
  id           String   @id @default(cuid())
  sessionId    String
  type         String
  path         String
  referrer     String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  utmTerm      String?
  utmContent   String?
  country      String?
  userAgent    String?
  contactId    String?
  props        Json?
  createdAt    DateTime @default(now())

  @@index([type, path, createdAt])
  @@index([sessionId])
  @@index([path, createdAt])
  @@index([contactId])
  @@map("track_events")
}

// ─── 5주 챌린지 (기수·주차·숙제·피드백) ────────────────────────────────────
model ChallengeCohort {
  id             String   @id @default(cuid())
  productSlug    String   // "5-week-challenge" | "5-week-challenge-plus-consulting"
  name           String   // "2026년 7월 기수"
  week1StartAt   DateTime // Week 1 오픈 시각 (UTC 저장, KST 09:00 등)
  weeksTotal     Int      @default(5)
  isActive       Boolean  @default(true)
  accessPassword String? // 공용 입장 비밀번호. 참여자가 최초 1회 입력 → 등록됨. 비우면 비번 입장 비활성
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  weeks       ChallengeWeek[]
  enrollments ChallengeEnrollment[]

  @@index([productSlug, week1StartAt])
  @@map("challenge_cohorts")
}

// 공용 비밀번호로 입장한 참여자 명단 (구매 없이 챌린지 접근 허용)
model ChallengeEnrollment {
  id        String   @id @default(cuid())
  cohortId  String
  userId    String
  createdAt DateTime @default(now())

  cohort ChallengeCohort @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cohortId, userId])
  @@index([userId])
  @@map("challenge_enrollments")
}

model ChallengeWeek {
  id                   String   @id @default(cuid())
  cohortId             String
  weekIndex            Int // 1~5
  title                String
  description          String   @default("") @db.Text // 이번 주 안내 (HTML)
  homeworkPrompt       String   @default("") @db.Text // 팁스타그램의 편지 본문
  openAt               DateTime
  homeworkDueAt        DateTime
  liveAt               DateTime?
  zoomUrl              String?
  recordingUrl         String?
  recommendedLessonIds Json? // marketing-booster lesson id 배열
  externalVideos       Json? // 참고 영상 배열: [{ title, url, description? }]
  materials            Json? // 강의 자료 배열: [{ title, url, filename, size? }]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  cohort      ChallengeCohort      @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  submissions HomeworkSubmission[]
  reminderSends ChallengeReminderSend[]

  @@unique([cohortId, weekIndex])
  @@index([openAt])
  @@map("challenge_weeks")
}

model HomeworkSubmission {
  id           String    @id @default(cuid())
  weekId       String
  userId       String
  content      String    @default("") @db.Text // 사람이 읽는 요약 텍스트 (자동 조립)
  formData     Json? // 주차별 구조화된 답변 (질문 답변 배열 · 조사한 사람 리스트 등)
  imageUrls    String[]  @default([])
  instagramUrl String?
  status       String    @default("submitted") // submitted | feedback_given
  submittedAt  DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  feedbackJson Json? // 5블록 원본 구조 (customerFeedback · productFeedback · profileLines · viralReels · recommendedAccounts · categoryHints)
  feedbackHtml String?   @db.Text
  feedbackBy   String? // admin userId
  feedbackAt   DateTime?

  week ChallengeWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([weekId, userId])
  @@index([userId, submittedAt])
  @@index([status, feedbackAt])
  @@map("homework_submissions")
}

model ChallengeReminderSend {
  id       String   @id @default(cuid())
  weekId   String
  stepKey  String // "open" | "live_d1" | "live_1h" | "due_d1" | "recording"
  userId   String
  status   String   @default("sent") // sent | failed
  error    String?
  sentAt   DateTime @default(now())

  week ChallengeWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)

  @@unique([weekId, stepKey, userId])
  @@index([weekId, sentAt])
  @@map("challenge_reminder_sends")
}
